# ─── Database ────────────────────────────────────────────────────────────────
# SQLite (development) — file path relative to /prisma/
DATABASE_URL="file:./dev.db"

# PostgreSQL (production) — uncomment and fill in:
# DATABASE_URL="postgresql://user:password@host:5432/aqa_event_card?sslmode=require"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Full URL of this app (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE_WITH_LONG_RANDOM_SECRET"

# ─── Admin seed credentials ───────────────────────────────────────────────────
# Used only during `npm run db:seed` to create the first super_admin account
ADMIN_EMAIL="admin@aqasports.com"
ADMIN_PASSWORD="REPLACE_WITH_STRONG_PASSWORD"

# ─── Public site URL ──────────────────────────────────────────────────────────
# Base URL encoded into QR codes — must be the public-facing domain
PUBLIC_SITE_URL="http://localhost:3000"
# Production example:
# PUBLIC_SITE_URL="https://aqasports.com"

# ─── Admin Notification Settings ──────────────────────────────────────────────
# Phone number to receive WhatsApp notification alerts for card demands
ADMIN_NOTIFICATION_PHONE="+213540454907"
