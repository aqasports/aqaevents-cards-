generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "sqlite"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("staff")
  createdAt    DateTime @default(now())

  ledgerEntries LedgerEntry[]
  redemptions   Redemption[]
  auditLogs     AuditLog[]
}

model Client {
  id        String   @id @default(cuid())
  fullName  String
  email     String?
  phone     String?
  notes     String?
  archived   Boolean  @default(false)
  archivedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // CRM Fields
  leadSource       String?
  customerSegment  String    @default("Standard")
  totalSpent       Int       @default(0)
  lastActivityDate DateTime?
  favoriteActivity String?

  cards            Card[]
  ledgerEntries    LedgerEntry[]
  redemptions      Redemption[]
  invoices         Invoice[]
  notificationLogs NotificationLog[]
}

model Card {
  id          String   @id @default(cuid())
  clientId    String? // null = pre-printed blank, not yet assigned to a client
  publicToken String   @unique
  cardCode    String   @unique
  status      String   @default("active") // active | voided
  issuedAt    DateTime @default(now())

  client        Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  ledgerEntries LedgerEntry[]

  @@index([clientId])
}

model Package {
  id           String   @id @default(cuid())
  name         String
  creditAmount Int // Activities the client pays for
  bonusCredits Int      @default(0) // Free bonus activities added on top
  totalCredits Int // Computed: creditAmount + bonusCredits
  price        Int // creditAmount × 1900
  active       Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  ledgerEntries LedgerEntry[]
}

model Activity {
  id            String   @id @default(cuid())
  name          String
  description   String?
  creditCost    Float    @default(1.0)
  imageUrl      String?
  places        String?
  duration      String? // e.g. "2h", "Half day", "Full day"
  gallery       String? // JSON: [{type:"image"|"video", url:string, caption:string?}]
  equipment     String? // JSON: [{name:string, type:"rent"|"buy"|"provided", price:number?}]
  active        Boolean  @default(true)
  eventType     String   @default("fixed")
  requiresCheck Boolean  @default(false) // Whether club check-in scanning is required
  createdAt     DateTime @default(now())

  sessions    ActivitySession[]
  redemptions Redemption[]
  expenses    ActivityExpense[]
}

model ActivityExpense {
  id         String   @id @default(cuid())
  activityId String
  name       String
  amount     Int
  notes      String?
  createdAt  DateTime @default(now())

  activity        Activity         @relation(fields: [activityId], references: [id], onDelete: Cascade)
  sessionExpenses SessionExpense[]

  @@index([activityId])
}

model ActivitySession {
  id          String   @id @default(cuid())
  activityId  String
  sessionDate DateTime
  location    String?
  capacity    Int?
  active      Boolean  @default(true)
  clubId      String?  // Optional: club assigned to host/check this session
  createdAt   DateTime @default(now())

  activity        Activity         @relation(fields: [activityId], references: [id], onDelete: Cascade)
  club            Club?            @relation(fields: [clubId], references: [id], onDelete: SetNull)
  redemptions     Redemption[]
  sessionExpenses SessionExpense[]
  clubCheckIns    ClubCheckIn[]

  @@index([activityId])
  @@index([sessionDate])
  @@index([clubId])
}

model SessionExpense {
  id                String   @id @default(cuid())
  sessionId         String
  activityExpenseId String
  quantity          Float    @default(1.0)
  amount            Int      // Stored calculated amount (e.g. quantity * unitPrice or override amount)
  createdAt         DateTime @default(now())

  session         ActivitySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  activityExpense ActivityExpense @relation(fields: [activityExpenseId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([activityExpenseId])
}

model LedgerEntry {
  id           String   @id @default(cuid())
  clientId     String
  cardId       String?
  packageId    String?
  redemptionId String?
  delta        Float
  type         String
  reason       String?
  createdById  String?
  createdAt    DateTime @default(now())

  client     Client      @relation(fields: [clientId], references: [id], onDelete: Restrict)
  card       Card?       @relation(fields: [cardId], references: [id], onDelete: SetNull)
  package    Package?    @relation(fields: [packageId], references: [id], onDelete: SetNull)
  redemption Redemption? @relation(fields: [redemptionId], references: [id], onDelete: Cascade)
  createdBy  AdminUser?  @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([createdAt])
}

model Redemption {
  id          String   @id @default(cuid())
  clientId    String
  activityId  String
  sessionId   String?
  creditsUsed Float    @default(1.0)
  staffId     String?
  redeemedAt  DateTime @default(now())
  notes       String?

  client        Client           @relation(fields: [clientId], references: [id], onDelete: Restrict)
  activity      Activity         @relation(fields: [activityId], references: [id], onDelete: Cascade)
  session       ActivitySession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  staff         AdminUser?       @relation(fields: [staffId], references: [id], onDelete: SetNull)
  ledgerEntries LedgerEntry[]

  @@index([clientId])
  @@index([redeemedAt])
}

model Invoice {
  id          String    @id @default(cuid())
  clientId    String
  invoiceCode String    @unique
  amount      Int
  status      String    @default("paid")
  category    String    @default("package")
  items       String
  notes       String?
  paidAt      DateTime?
  createdAt   DateTime  @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Restrict)

  @@index([clientId])
  @@index([createdAt])
  @@index([status])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String // e.g. "RESET_DATA", "CREATE_PACKAGE", "DELETE_ACTIVITY"
  target    String // Target description
  details   String? // Detail info
  ipAddress String?
  createdAt DateTime @default(now())

  user AdminUser? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
}

model NotificationLog {
  id        String   @id @default(cuid())
  clientId  String
  type      String // "sms" | "email"
  recipient String // target phone or email
  subject   String?
  message   String
  status    String // "sent" | "failed"
  sentAt    DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([sentAt])
}

model Product {
  id          String   @id @default(cuid())
  name        String
  price       Int
  description String?
  imageUrl    String?
  advertised  Boolean  @default(true)
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CardDemand {
  id          String   @id @default(cuid())
  name        String
  phone       String
  email       String?  // Optional email
  creditType  String   // "package" or "custom"
  packageId   String?
  amount      Int?     // For custom credits
  price       Int      // Computed price in DA (Algerian Dinars)
  status      String   @default("pending") // "pending", "accepted", "rejected"
  cardCode    String?  // Linked physical card code (e.g. AQA-989734)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

model ActivityProposal {
  id          String   @id @default(cuid())
  title       String
  description String
  userName    String
  userPhone   String
  userEmail   String?
  status      String   @default("pending") // "pending", "reviewed", "archived"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

// ─── Club Check-In System ────────────────────────────────────────────────────

// A Club is a third-party organisation that hosts AQA sessions on-site.
// Each club has a unique secret token that generates a terminal URL.
// The terminal allows a club agent to scan AQA cards and record attendance.
model Club {
  id        String   @id @default(cuid())
  name      String
  contact   String?  // Phone or email of the club contact
  token     String   @unique @default(cuid()) // Secret token for the terminal URL
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  sessions ActivitySession[]
  checkIns ClubCheckIn[]
}

// Records a single card scan / attendance confirmation at a club terminal.
model ClubCheckIn {
  id        String   @id @default(cuid())
  clubId    String
  sessionId String
  cardId    String
  clientId  String
  checkedAt DateTime @default(now())

  club    Club            @relation(fields: [clubId], references: [id], onDelete: Cascade)
  session ActivitySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, cardId]) // Prevents double check-in
  @@index([clubId])
  @@index([sessionId])
  @@index([checkedAt])
}
