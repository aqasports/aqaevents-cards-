generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("staff")
  createdAt    DateTime @default(now())

  ledgerEntries LedgerEntry[]
  redemptions   Redemption[]
  auditLogs     AuditLog[]
}

model Client {
  id        String   @id @default(cuid())
  fullName  String
  email     String?
  phone     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // CRM Fields
  leadSource        String?
  customerSegment   String    @default("Standard")
  totalSpent        Int       @default(0)
  lastActivityDate  DateTime?
  favoriteActivity  String?

  cards            Card[]
  ledgerEntries    LedgerEntry[]
  redemptions      Redemption[]
  invoices         Invoice[]
  notificationLogs NotificationLog[]
}

model Card {
  id          String   @id @default(cuid())
  clientId    String?   // null = pre-printed blank, not yet assigned to a client
  publicToken String   @unique
  cardCode    String   @unique
  status      String   @default("active") // active | voided
  issuedAt    DateTime @default(now())

  client        Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  ledgerEntries LedgerEntry[]

  @@index([clientId])
}

model Package {
  id            String   @id @default(cuid())
  name          String
  creditAmount  Int      // Activities the client pays for
  bonusCredits  Int      @default(0) // Free bonus activities added on top
  totalCredits  Int      // Computed: creditAmount + bonusCredits
  price         Int      // creditAmount × 1900
  active        Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())

  ledgerEntries LedgerEntry[]
}

model Activity {
  id          String   @id @default(cuid())
  name        String
  description String?
  creditCost  Int      @default(1)
  imageUrl    String?
  places      String?
  duration    String?   // e.g. "2h", "Half day", "Full day"
  gallery     String?   // JSON: [{type:"image"|"video", url:string, caption:string?}]
  equipment   String?   // JSON: [{name:string, type:"rent"|"buy"|"provided", price:number?}]
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  sessions    ActivitySession[]
  redemptions Redemption[]
  expenses    ActivityExpense[]
}

model ActivityExpense {
  id          String   @id @default(cuid())
  activityId  String
  name        String
  amount      Int
  notes       String?
  createdAt   DateTime @default(now())

  activity    Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@index([activityId])
}

model ActivitySession {
  id         String   @id @default(cuid())
  activityId String
  sessionDate DateTime
  location   String?
  capacity   Int?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  activity    Activity     @relation(fields: [activityId], references: [id], onDelete: Cascade)
  redemptions Redemption[]

  @@index([activityId])
  @@index([sessionDate])
}

model LedgerEntry {
  id        String   @id @default(cuid())
  clientId  String
  cardId    String?
  packageId String?
  redemptionId String?
  delta     Int
  type      String
  reason    String?
  createdById String?
  createdAt DateTime @default(now())

  client    Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  card      Card?      @relation(fields: [cardId], references: [id], onDelete: SetNull)
  package   Package?   @relation(fields: [packageId], references: [id], onDelete: SetNull)
  redemption Redemption? @relation(fields: [redemptionId], references: [id], onDelete: Cascade)
  createdBy AdminUser? @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([createdAt])
}

model Redemption {
  id          String   @id @default(cuid())
  clientId    String
  activityId  String
  sessionId   String?
  creditsUsed Int      @default(1)
  staffId     String?
  redeemedAt  DateTime @default(now())
  notes       String?

  client   Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  activity Activity         @relation(fields: [activityId], references: [id], onDelete: Cascade)
  session  ActivitySession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  staff    AdminUser?       @relation(fields: [staffId], references: [id], onDelete: SetNull)
  ledgerEntries LedgerEntry[]

  @@index([clientId])
  @@index([redeemedAt])
}

model Invoice {
  id          String    @id @default(cuid())
  clientId    String
  invoiceCode String    @unique
  amount      Int
  status      String    @default("paid")
  category    String    @default("package")
  items       String
  notes       String?
  paidAt      DateTime?
  createdAt   DateTime  @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([createdAt])
  @@index([status])
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String   // e.g. "RESET_DATA", "CREATE_PACKAGE", "DELETE_ACTIVITY"
  target      String   // Target description
  details     String?  // Detail info
  ipAddress   String?
  createdAt   DateTime @default(now())

  user        AdminUser? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
}

model NotificationLog {
  id          String   @id @default(cuid())
  clientId    String
  type        String   // "sms" | "email"
  recipient   String   // target phone or email
  subject     String?
  message     String
  status      String   // "sent" | "failed"
  sentAt      DateTime @default(now())

  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([sentAt])
}

model Product {
  id          String   @id @default(cuid())
  name        String
  price       Int
  description String?
  imageUrl    String?
  advertised  Boolean  @default(true)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

