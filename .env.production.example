# ─── PRODUCTION ENVIRONMENT ───────────────────────────────────────────────────
# These variables are set ONLY in the Netlify Dashboard > Site > Environment Variables.
# They must NEVER appear in any file committed to Git.
#
# DATABASE_URL=<set in Netlify>
# DIRECT_URL=<set in Netlify>
# NEXTAUTH_SECRET=<set in Netlify - generate with: openssl rand -base64 32>
# ADMIN_EMAIL=<set in Netlify>
# ADMIN_PASSWORD=<set in Netlify>
# DISABLE_DATA_RESET=true
#
# ─── LOCAL DEVELOPMENT ────────────────────────────────────────────────────────
# For local development, use the Docker PostgreSQL database:
#
# DATABASE_URL="postgresql://aqa_user:aqa_password@localhost:5432/aqa_event_card"
# NEXTAUTH_URL="http://localhost:3000"
# NEXTAUTH_SECRET="dev-secret-change-in-production-abc123xyz"
# ADMIN_EMAIL="admin@aqasports.com"
# ADMIN_PASSWORD="your-password-here"
# PUBLIC_SITE_URL="http://localhost:3000"
#
# Start the local database with: docker-compose up -d
# Then push the schema: npx prisma db push
# Then seed test data: npm run db:seed
